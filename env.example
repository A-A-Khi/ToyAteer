# انسخ هذا الملف إلى `.env.local` في جذر المشروع، ثم عبّئ القيم.
# بعد أي تعديل على المتغيرات العامة NEXT_PUBLIC_* أعد تشغيل الخادم: npm run dev
#
# الاستضافة (مثل Vercel): أضف نفس المتغيرات في Project → Settings → Environment Variables
# للـ Production و Preview، وإلا لن تظهر ملفات Supabase على الموقع المنشور.

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# مفتاح الخدمة (سري — للخادم فقط، لا تبدأ بـ NEXT_PUBLIC):
# من Supabase → Project Settings → API → service_role
# يُستخدم لرفع/حذف/قائمة الملفات عبر /api/admin ويتجاوز RLS.
# بدونه قد يظهر خطأ: new row violates row-level security policy
SUPABASE_SERVICE_ROLE_KEY=

# كلمة مرور لوحة الإدارة (/admin) — يجب أن تبدأ بـ NEXT_PUBLIC_ لتعمل في المتصفح
NEXT_PUBLIC_ADMIN_PASSWORD=
